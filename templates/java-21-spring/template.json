{
  "variables": [
    {
      "name": "GROUP_ID",
      "prompt": "Maven groupId",
      "default": "com.kotaketech"
    },
    {
      "name": "PACKAGE_NAME",
      "prompt": "Base Java package (e.g. com.kotaketech.myservice)",
      "default": "com.kotaketech.myservice"
    },
    {
      "name": "DESCRIPTION",
      "prompt": "Project description",
      "default": "Service generated via ktk-init"
    },
    {
      "name": "KOTAKE_VERSION",
      "prompt": "kotake-parent version",
      "default": "1.0.0-SNAPSHOT"
    }
  ]
}
